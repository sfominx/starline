{
    "$schema": "https://www.raycast.com/schemas/extension.json",
    "name": "starline",
    "title": "Starline",
    "description": "Manage your Starline devices. Requires developer account.",
    "icon": "command-icon.png",
    "author": "sergey_fomin",
    "license": "MIT",
    "commands": [
        {
            "name": "devices",
            "title": "Devices",
            "description": "List Starline devices you have",
            "mode": "view"
        },
        {
            "name": "arm",
            "title": "Arm",
            "description": "Arm the default device",
            "mode": "no-view"
        },
        {
            "name": "disarm",
            "title": "Disarm",
            "description": "Disarm the default device",
            "mode": "no-view"
        },
        {
            "name": "start_engine",
            "title": "Start Engine",
            "description": "Start engine on the default device",
            "mode": "no-view"
        },
        {
            "name": "stop_engine",
            "title": "Stop Engine",
            "description": "Stop engine on the default device",
            "mode": "no-view"
        },
        {
            "name": "arm_quietly",
            "title": "Arm Quietly",
            "description": "Arm the default device without sound confirmation",
            "mode": "no-view"
        },
        {
            "name": "disarm_quietly",
            "title": "Disarm Quietly",
            "description": "Disarm the default device without sound confirmation",
            "mode": "no-view"
        },
        {
            "name": "horn",
            "title": "Horn",
            "description": "Send horn command to the default device",
            "mode": "no-view"
        },
        {
            "name": "update_position",
            "title": "Update Position",
            "description": "Request position update for the default device",
            "mode": "no-view"
        }
    ],
    "preferences": [
        {
            "name": "AppId",
            "type": "password",
            "required": true,
            "title": "Application ID",
            "description": "The AppId value seen in the Developer section of a Starline account.",
            "placeholder": "AppID"
        },
        {
            "name": "Secret",
            "type": "password",
            "required": true,
            "title": "Secret",
            "description": "The Secret value seen in the Developer section of a Starline account.",
            "placeholder": "Secret"
        },
        {
            "name": "Login",
            "required": true,
            "type": "textfield",
            "title": "Login",
            "description": "Your Starline login.",
            "placeholder": "Login"
        },
        {
            "name": "Password",
            "type": "password",
            "required": true,
            "title": "Password",
            "description": "Your Starline password.",
            "placeholder": "Password"
        }
    ],
    "dependencies": {
        "@raycast/api": "^1.65.1",
        "node-fetch": "^3.3.2",
        "react": "^18.2.0"
    },
    "devDependencies": {
        "@raycast/eslint-config": "^1.0.8",
        "@types/jest": "^30.0.0",
        "@types/node": "20.11.5",
        "@types/react": "18.2.48",
        "@types/react-test-renderer": "^18.0.7",
        "eslint": "^8.56.0",
        "eslint-config-airbnb": "^19.0.4",
        "eslint-import-resolver-typescript": "^3.6.1",
        "eslint-plugin-import": "^2.29.1",
        "eslint-plugin-jsx-a11y": "^6.8.0",
        "eslint-plugin-prettier": "^5.1.3",
        "eslint-plugin-promise": "^6.1.1",
        "eslint-plugin-react": "^7.33.2",
        "eslint-plugin-react-hooks": "^4.6.0",
        "jest": "^29.7.0",
        "prettier": "^3.2.4",
        "react-test-renderer": "^18.2.0",
        "ts-jest": "^29.4.9",
        "ts-prune": "^0.10.3",
        "tslint-lines-between-class-members": "^1.3.6",
        "typescript": "^5.3.3"
    },
    "scripts": {
        "build": "ray build -e dist",
        "dev": "ray develop",
        "fix-lint": "ray lint --fix",
        "lint": "ray lint",
        "test": "jest",
        "publish": "npx @raycast/api@latest publish"
    }
}
